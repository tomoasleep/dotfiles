#!/bin/bash
set -eu

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AGENT_PACKS_DIR="$DOTFILES_ROOT/config/agent-packs"
TARGET_DIRS=("$HOME/.agents/skills" "$HOME/.claude/skills")

for target_dir in "${TARGET_DIRS[@]}"; do
  mkdir -p "$target_dir"
done

for pack_dir in "$AGENT_PACKS_DIR"/*/; do
  skills_dir="$pack_dir/skills"
  [[ -d "$skills_dir" ]] || continue

  for skill_path in "$skills_dir"/*/; do
    [[ -d "$skill_path" ]] || continue

    skill_name=$(basename "$skill_path")

    for target_dir in "${TARGET_DIRS[@]}"; do
      symlink="$target_dir/$skill_name"

      if [[ -L "$symlink" ]]; then
        rm "$symlink"
      elif [[ -e "$symlink" ]]; then
        echo "Warning: $symlink exists and is not a symlink, skipping"
        continue
      fi

      ln -s "$skill_path" "$symlink"
      echo "Linked: $symlink -> $skill_path"
    done
  done
done

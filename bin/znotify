#!/usr/bin/env bash

EMOJI=$1

if [ -n "$ZELLIJ" ]; then
  zellij pipe --name emotitle --plugin zellij-emotitle --args target=tab,pane_id=$ZELLIJ_PANE_ID,emojis=$EMOJI > /dev/null
  zellij pipe --name emotitle --plugin zellij-emotitle --args target=pane,pane_id=$ZELLIJ_PANE_ID,emojis=$EMOJI > /dev/null
elif [ -n "$CMUX_WORKSPACE_ID" ]; then
  cmux notify --title "$EMOJI" --body ""
fi


#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: gh-comment <type> <number> --agent <agent-name> [--repo <owner/repo>]

Arguments:
  type    Target type: issue or pr
  number  Issue or PR number

Options:
  --agent  Agent name for the generated footer: Claude Code, OpenCode, or Codex
  --repo  Repository in owner/repo format (defaults to current repo)

The comment body is read from stdin.

Examples:
  echo "Hello!" | gh-comment issue 42 --agent "OpenCode"
  echo "LGTM" | gh-comment pr 10 --agent "Claude Code" --repo owner/repo
  cat comment.md | gh-comment issue 42 --agent "Codex"
EOF
  exit 1
}

TYPE=""
NUMBER=""
AGENT=""
REPO_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    issue|pr)
      TYPE="$1"
      shift
      ;;
    --repo)
      REPO_ARGS=("--repo" "$2")
      shift 2
      ;;
    --agent)
      AGENT="$2"
      shift 2
      ;;
    --help|-h)
      usage
      ;;
    *)
      if [[ -z "$NUMBER" ]]; then
        NUMBER="$1"
        shift
      else
        echo "Error: Unexpected argument: $1" >&2
        usage
      fi
      ;;
  esac
done

if [[ -z "$TYPE" || -z "$NUMBER" || -z "$AGENT" ]]; then
  echo "Error: type, number, and --agent are required" >&2
  usage
fi

case "$AGENT" in
  "Claude Code"|"OpenCode"|"Codex")
    ;;
  *)
    echo "Error: --agent must be one of: Claude Code, OpenCode, Codex" >&2
    usage
    ;;
esac

if [[ -t 0 ]]; then
  echo "Error: Comment body must be provided via stdin" >&2
  usage
fi

BODY_FILE=$(mktemp)
trap 'rm -f "$BODY_FILE"' EXIT

cat > "$BODY_FILE"

if [[ -s "$BODY_FILE" ]]; then
  printf '\n> :robot: Generated by %s\n' "$AGENT" >> "$BODY_FILE"
else
  printf '> :robot: Generated by %s\n' "$AGENT" >> "$BODY_FILE"
fi

case "$TYPE" in
  issue)
    gh issue comment "$NUMBER" "${REPO_ARGS[@]}" --body-file "$BODY_FILE"
    ;;
  pr)
    gh pr comment "$NUMBER" "${REPO_ARGS[@]}" --body-file "$BODY_FILE"
    ;;
  *)
    echo "Error: type must be 'issue' or 'pr'" >&2
    usage
    ;;
esac

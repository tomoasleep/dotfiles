// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          // "updateImportsOnFileMove": {
          //   "enabled": "always",
          // },
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          // "updateImportsOnFileMove": {
          //   "enabled": "always",
          // },
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:0.5b"
    },
    "provider": "ollama",
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "Example Agent": {
      "type": "custom",
      "command": "npx",
      "args": [
        "tsx",
        "/Users/tomoya/.ghq/github.com/agentclientprotocol/typescript-sdk/src/examples/agent.ts",
      ],
      "env": {},
    },
  },
  "agent": {
    "dock": "right",
    "play_sound_when_agent_done": "always",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "theme": {
    "mode": "light",
    "light": "Everforest Light Medium (regular)",
    "dark": "Everforest Dark Medium (blur)",
  },
  "buffer_font_size": 14,
  "ui_font_family": "HackGen35 Console",
  "vim_mode": true,
  "terminal": {
    "dock": "right",
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph", "steep"],
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
        "source.organizeImports": true,
      },
    },
    "TypeScript": {
      "code_actions_on_format": {
        // "source.organizeImports": true,
        "source.fixAll.eslint": true,
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
  },
}
